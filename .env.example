# =============================================================================
# JSHook Reverse Tool - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values

# -----------------------------------------------------------------------------
# Required: LLM API Configuration
# -----------------------------------------------------------------------------
# Choose one: OpenAI or Anthropic

# Option 1: OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
DEFAULT_LLM_PROVIDER=openai

# Option 2: Anthropic (uncomment to use)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# DEFAULT_LLM_PROVIDER=anthropic

# -----------------------------------------------------------------------------
# Optional: Puppeteer Configuration
# -----------------------------------------------------------------------------
# Whether to run browser in headless mode (true/false)
PUPPETEER_HEADLESS=false

# Browser operation timeout in milliseconds
PUPPETEER_TIMEOUT=30000

# -----------------------------------------------------------------------------
# Optional: Cache and Performance
# -----------------------------------------------------------------------------
# Enable caching to reduce API calls
ENABLE_CACHE=true

# Log level: debug, info, warn, error
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Optional: Advanced Settings
# -----------------------------------------------------------------------------
# Chrome executable path (leave empty to use bundled Chromium)
# PUPPETEER_EXECUTABLE_PATH=

# Browser viewport width
# PUPPETEER_VIEWPORT_WIDTH=1920

# Browser viewport height
# PUPPETEER_VIEWPORT_HEIGHT=1080
